# MyeCA.in Environment Variables
# Copy this file to .env for local development and add the same values in Vercel.

# App
NODE_ENV=development
APP_URL=http://localhost:5000
VITE_APP_URL=http://localhost:5000

# Clerk authentication
VITE_CLERK_PUBLISHABLE_KEY=
# Optional Vercel Marketplace/Next-compatible alias; the Vite app accepts either public key.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Neon Postgres
DATABASE_URL=
# Vercel Marketplace Neon may provision POSTGRES_URL instead; the app accepts either.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Role bootstrap
# Comma-separated email addresses that should be assigned admin on auth sync.
ADMIN_EMAILS=
TEAM_MEMBER_EMAILS=

# Security
SESSION_SECRET=
PII_ENCRYPTION_KEY=
BLOG_IMPORT_SECRET=

# Email services
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# AI features
OPENAI_API_KEY=

# Analytics
VITE_GA_MEASUREMENT_ID=
