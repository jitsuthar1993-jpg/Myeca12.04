# MyeCA.in Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# ================================
# REQUIRED FOR PRODUCTION DEPLOYMENT
# ================================

# JWT Secret for local operations (if needed)
JWT_SECRET=

# Database URL (REQUIRED)
# Google Cloud SQL connection string
DATABASE_URL=

# ================================
# SUPABASE CONFIGURATION
# ================================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Node Environment (REQUIRED for production)
# Set to "production" for deployment
NODE_ENV=production

# ================================
# OPTIONAL FEATURES
# ================================

# OpenAI API Key (for AI tax optimization features)
OPENAI_API_KEY=

# Email Service Configuration (choose one)
# Option 1: SendGrid
SENDGRID_API_KEY=

# Option 2: SMTP (alternative to SendGrid)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Session Secret (auto-generated if not provided)
SESSION_SECRET=

# ================================
# FRONTEND ENVIRONMENT VARIABLES
# ================================

# Google Analytics (optional)
VITE_GA_MEASUREMENT_ID=

# API Base URL (usually auto-configured)
VITE_API_BASE_URL=

# ================================
# SECURITY NOTES
# ================================

# 1. NEVER commit this file with real values to version control
# 2. Keep JWT_SECRET secure and rotate it periodically
# 3. Use different secrets for development and production
# 4. Ensure NODE_ENV=production for deployment
# 5. Use strong, unique passwords for all services

# ================================
# DEPLOYMENT CHECKLIST
# ================================

# ✅ JWT_SECRET set (at least 32 characters)
# ✅ DATABASE_URL configured
# ✅ NODE_ENV=production
# ✅ All secrets added to Replit Deployment Environment Variables
# ✅ Application tested locally
# ✅ Ready for deployment