# MyeCA.in Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# ================================
# FIREBASE CONFIGURATION (REQUIRED)
# ================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Service Account Key (JSON string or path to file)
FIREBASE_SERVICE_ACCOUNT_KEY=

# reCAPTCHA Enterprise for App Check
VITE_RECAPTCHA_SITE_KEY=

# ================================
# AUTHENTICATION & SECURITY
# ================================
JWT_SECRET=
SESSION_SECRET=
PII_ENCRYPTION_KEY=

# ================================
# DATABASE
# ================================
DATABASE_URL=

# ================================
# EMAIL SERVICES (choose one or more)
# ================================

# AWS SES
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION=

# SendGrid
SENDGRID_API_KEY=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ================================
# AI FEATURES (optional)
# ================================
OPENAI_API_KEY=

# ================================
# ROLE OVERRIDES (optional)
# ================================
# Comma-separated emails that get specific roles automatically
ADMIN_EMAILS=
TEAM_MEMBER_EMAILS=
VITE_ADMIN_EMAILS=
VITE_TEAM_MEMBER_EMAILS=

# ================================
# ANALYTICS (optional)
# ================================
VITE_GA_MEASUREMENT_ID=

# ================================
# ENVIRONMENT
# ================================
NODE_ENV=development
