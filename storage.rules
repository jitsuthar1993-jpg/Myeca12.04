rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    
    function isTeamMember() {
      return isAuthenticated() && (
        getUserData().role == 'admin' || 
        getUserData().role == 'team_member' ||
        getUserData().role == 'ca'
      );
    }

    // User document uploads
    match /user_documents/{userId}/{allPaths=**} {
      allow read, write: if isAuthenticated() && (
        request.auth.uid == userId || 
        isTeamMember()
      );
      
      // Strict size and type checks for any uploads
      allow write: if isAuthenticated() && request.auth.uid == userId && 
                    request.resource.size < 5 * 1024 * 1024 && // 5MB limit
                    request.resource.contentType.matches('image/.*|application/pdf|application/vnd.openxmlformats-officedocument.*|application/vnd.ms-excel|application/msword');
    }

    // Public assets (Logos, Icons, etc.)
    match /public_assets/{allPaths=**} {
      allow read: if true;
      allow write: if isTeamMember();
    }

    // Temporary/Scratch space
    match /tmp/{userId}/{allPaths=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
